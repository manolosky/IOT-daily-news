// Copy this file to src/secrets.h and fill with your credentials.
// Do NOT commit src/secrets.h to version control.

#ifndef SECRETS_H
#define SECRETS_H

// Wi-Fi
#define WIFI_SSID "your_ssid"
#define WIFI_PASS "your_password"

// NewsAPI key
#define API_KEY "your_newsapi_key"

// Weather location — city used for geocoding and shown on the display.
// Use a plain-ASCII spelling so the TFT fonts render it correctly.
// WEATHER_COUNTRY is optional (ISO-2 code or country name) and disambiguates
// cities that share the same name.
#define WEATHER_CITY "Madrid"
#define WEATHER_COUNTRY "ES"

#endif // SECRETS_H
